# ─── Google Sheets — LECTURA (sheet público) ──────────────────────────────────
# Obtén una API Key en Google Cloud Console → Credentials → API Key
# Restringe la key solo a "Google Sheets API"
GOOGLE_API_KEY=AIzaSy...tu_api_key_aqui

# ─── Google Sheets — ESCRITURA (Service Account) ──────────────────────────────
# Necesario para registrar confirmaciones automáticamente.
# Crea un Service Account en Google Cloud Console → Credentials
# Comparte el Sheet con el email del Service Account como Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\ntu_clave_privada\n-----END RSA PRIVATE KEY-----"

# ─── Hoja de cálculo ──────────────────────────────────────────────────────────
GOOGLE_SPREADSHEET_ID=17MlwQuAgBGFWJQBpSd7yAZZ3DHghc3uMIqNSTUU2Zf0

# Nombre exacto de la pestaña (ej: Sheet1, Hoja1, Participantes…)
GOOGLE_SHEET_NAME=Sheet1

# ─── Dashboard ────────────────────────────────────────────────────────────────
# Contraseña para acceder al panel de control en /dashboard
# Si se deja vacío, cualquiera con la URL puede entrar.
DASHBOARD_PASSWORD=buen2025
