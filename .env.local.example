# ─── Sin credenciales de Google ────────────────────────────────────────────────
# El sheet debe estar configurado como público (cualquiera con el enlace puede ver).
# La lectura se hace vía URL pública de CSV — no requiere API key ni Service Account.

# ─── Opcional: hoja distinta ───────────────────────────────────────────────────
# Solo necesario si cambias el spreadsheet o el nombre de la pestaña.
# GOOGLE_SPREADSHEET_ID=17MlwQuAgBGFWJQBpSd7yAZZ3DHghc3uMIqNSTUU2Zf0
# GOOGLE_SHEET_NAME=Sheet1

# ─── Apps Script (para escribir CONFIRMÓ) ──────────────────────────────────────
# Sigue las instrucciones en /apps-script/confirmar.js para obtener esta URL.
# Si no se configura, la app funciona igual pero no registra confirmaciones.
APPS_SCRIPT_URL=https://script.google.com/macros/s/TU_ID_AQUI/exec

# ─── Dashboard ─────────────────────────────────────────────────────────────────
# Clave por defecto: buencomienzo123
# Solo agrega esta variable si quieres cambiarla.
# DASHBOARD_PASSWORD=buencomienzo123
